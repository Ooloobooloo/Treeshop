<!doctype html>
<html lang="en" class="light-style layout-navbar-fixed layout-menu-fixed layout-compact" dir="ltr"
  data-theme="theme-default" data-assets-path="../../assets/" data-template="vertical-menu-template" data-style="light">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />

  <title>Tree List | Materio</title>
  <meta name="description" content="Tree Management" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="../../assets/img/favicon/favicon.ico" />

  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../../assets/vendor/fonts/remixicon/remixicon.css" />

  <!-- Core CSS -->
  <link rel="stylesheet" href="../../assets/vendor/css/rtl/core.css" class="template-customizer-core-css" />
  <link rel="stylesheet" href="../../assets/vendor/css/rtl/theme-default.css" class="template-customizer-theme-css" />
  <link rel="stylesheet" href="../../assets/css/demo.css" />

  <!-- Vendors -->
  <link rel="stylesheet" href="../../assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css" />
</head>

<body>
  <div class="layout-wrapper layout-content-navbar">
    <div class="layout-container">

      <!-- Menu -->
      <%- include('partials/vertical_nav') %>   <!-- Reuse your sidebar if you have one -->

      <!-- Content wrapper -->
      <div class="layout-page">
       
        <!-- Content -->
        <div class="content-wrapper">
          <div class="container-xxl flex-grow-1 container-p-y">

            <h4 class="fw-bold py-3 mb-4">Tree Management</h4>

            <!-- Add Button -->
            <div class="d-flex justify-content-between align-items-center mb-4">
              <div></div>
              <a href="/trees/new" class="btn btn-primary">
                <i class="ri-add-line me-1"></i> Add New Tree
              </a>
            </div>

            <!-- Basic Table -->
            <div class="card">
              <h5 class="card-header">Tree List</h5>
              <div class="table-responsive text-nowrap">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>ID</th>
                      <th>Tree Name</th>
                      <th>Height (m)</th>
                      <th>Age (years)</th>
                      <th>Planted Date</th>
                      <th>Status</th>
                      <th class="text-center">Actions</th>
                    </tr>
                  </thead>
                  <tbody class="table-border-bottom-0">
                    <% if (trees && trees.length > 0) { %>
                      <% trees.forEach(tree => { %>
                        <tr>
                          <td><strong>#<%= tree.id %></strong></td>
                          <td><%= tree.name %></td>
                                                 
                            <span class="badge rounded-pill 
                              <%= tree.status === 'Healthy' ? 'bg-label-success' : 
                                  tree.status === 'Sick' ? 'bg-label-warning' : 'bg-label-secondary' %>">
                              <%= tree.status || 'Unknown' %>
                            </span>
                          </td>
                          <td class="text-center">
                            <div class="dropdown">
                              <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                <i class="ri-more-2-line"></i>
                              </button>
                              <div class="dropdown-menu">
                                <a class="dropdown-item" href="/trees/<%= tree.id %>/edit">
                                  <i class="ri-pencil-line me-1"></i> Edit
                                </a>
                                <form action="/trees/<%= tree.id %>/delete" method="POST" style="display:inline;">
                                  <button type="submit" class="dropdown-item text-danger"
                                    onclick="return confirm('Are you sure you want to delete this tree?')">
                                    <i class="ri-delete-bin-6-line me-1"></i> Delete
                                  </button>
                                </form>
                              </div>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="8" class="text-center py-4">
                          <i class="ri-tree-line ri-3x text-muted mb-3 d-block"></i>
                          <p class="text-muted">No trees found. Add your first tree!</p>
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Reset All Button -->
            <div class="mt-4 text-end">
              <form action="/reset" method="POST" onsubmit="return confirm('Reset all trees? This cannot be undone!')">
                <button type="submit" class="btn btn-outline-danger">
                  <i class="ri-refresh-line me-1"></i> Reset All Trees
                </button>
              </form>
            </div>

          </div>

          <!-- Footer -->
          <%- include('partials/footer') %>
        </div>
      </div>
    </div>
  </div>

  <!-- Core JS -->
  <script src="../../assets/vendor/libs/jquery/jquery.js"></script>
  <script src="../../assets/vendor/libs/popper/popper.js"></script>
  <script src="../../assets/vendor/js/bootstrap.js"></script>
  <script src="../../assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
  <script src="../../assets/vendor/js/menu.js"></script>
  <script src="../../assets/js/main.js"></script>

</body>
</html>