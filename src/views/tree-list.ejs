<!doctype html>
<html lang="en" class="light-style layout-navbar-fixed layout-menu-fixed layout-compact" dir="ltr"
  data-theme="theme-default" data-assets-path="/assets/" data-template="vertical-menu-template" data-style="light">
<head>
  <%- include('partials/header') %>
</head>
<body>
  <div class="layout-wrapper layout-content-navbar">
    <div class="layout-container">

      <!-- Vertical Navigation -->
      <%- include('partials/vertical_nav', { 
        currentPage: 'trees', 
        subPage: 'list' 
      }) %>

      <div class="layout-page">

        <!-- Không có top navbar như yêu cầu -->

        <div class="content-wrapper">
          <div class="container-xxl flex-grow-1 container-p-y">

            <% if (error) { %>
              <div class="alert alert-warning mb-4"><%= error %></div>
            <% } %>

            <h4 class="mb-4 fw-semibold">Tree Management</h4>

            <!-- 2 Tabs nội dung -->
            <ul class="nav nav-pills mb-4" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="list-tab" data-bs-toggle="tab" 
                        data-bs-target="#list-tab-pane" type="button" role="tab">
                  <i class="ri-list-check-2 ri-20px me-2"></i> Tree List
                </button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="add-tab" data-bs-toggle="tab" 
                        data-bs-target="#add-tab-pane" type="button" role="tab">
                  <i class="ri-add-circle-line ri-20px me-2"></i> Add New Tree
                </button>
              </li>
            </ul>

            <div class="tab-content">
              <!-- Tab 1: Tree List -->
              <div class="tab-pane fade show active" id="list-tab-pane" role="tabpanel">
                <div class="card">
                  <div class="card-body">
                    <div class="table-responsive text-nowrap">
                      <table class="table table-hover">
                        <thead>
                          <tr>
                            <th>Tree Name</th>
                            <th>Description</th>
                            <th>Image</th>
                            <th>Actions</th>
                          </tr>
                        </thead>
                        <tbody class="table-border-bottom-0">
                          <% if (trees && trees.length > 0) { %>
                            <% trees.forEach(tree => { %>
                              <tr>
                                <td>
                                  <i class="ri-leaf-fill ri-22px text-success me-4"></i>
                                  <%= tree.name %>
                                </td>
                                <td><%= tree.description || 'Chưa có mô tả' %></td>
                                <td>
                                  <% if (tree.image) { %>
                                    <img src="<%= tree.image %>" alt="<%= tree.name %>" 
                                         class="rounded" 
                                         style="max-height: 60px; width: auto; object-fit: cover;"
                                         onerror="this.onerror=null; this.src='https://placehold.co/100x60?text=No+Image';">
                                  <% } else { %>
                                    <span class="text-muted">-</span>
                                  <% } %>
                                </td>
                                <td>
                                  <div class="dropdown">
                                    <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                      <i class="ri-more-2-line"></i>
                                    </button>
                                    <div class="dropdown-menu">
                                      <a class="dropdown-item waves-effect" href="/trees/edit/<%= tree._id %>">
                                        <i class="ri-pencil-line me-1"></i> Edit
                                      </a>
                                      <form action="/trees/delete/<%= tree._id %>" method="POST" style="display: inline;">
                                        <button type="submit" class="dropdown-item text-danger waves-effect"
                                                onclick="return confirm('Bạn có chắc muốn xóa cây <%= tree.name %>?')">
                                          <i class="ri-delete-bin-6-line me-1"></i> Delete
                                        </button>
                                      </form>
                                    </div>
                                  </div>
                                </td>
                              </tr>
                            <% }) %>
                          <% } else { %>
                            <tr>
                              <td colspan="4" class="text-center py-4 text-muted">
                                Chưa có cây nào. Hãy thêm cây mới ở tab "Add New Tree".
                              </td>
                            </tr>
                          <% } %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Tab 2: Add New Tree -->
              <div class="tab-pane fade" id="add-tab-pane" role="tabpanel">
                <div class="card">
                  <h5 class="card-header">Add New Tree</h5>
                  <div class="card-body">
                    <form action="/trees" method="POST">
                      <div class="row g-4">
                        <div class="col-md-4">
                          <label class="form-label">Name</label>
                          <input class="form-control" type="text" name="name" placeholder="Tree Name" required>
                        </div>
                        <div class="col-md-4">
                          <label class="form-label">Description</label>
                          <input class="form-control" type="text" name="description" placeholder="Description" required>
                        </div>
                        <div class="col-md-4">
                          <label class="form-label">Image URL</label>
                          <input class="form-control" type="url" name="image" 
                                 placeholder="https://i.imgur.com/abc123.jpg">
                          <small class="text-muted">Dán link ảnh trực tiếp từ mạng</small>
                        </div>
                      </div>
                      <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Add Tree</button>
                        <button type="submit" formaction="/reset" class="btn btn-outline-danger">Reset All</button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

<!-- Edit Tree Modal -->
<div class="modal fade" id="editTreeModal" tabindex="-1" aria-labelledby="editTreeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editTreeModalLabel">Edit Tree</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="editTreeForm" action="" method="POST">
          <input type="hidden" id="treeId" name="id">

          <div class="row g-4">
            <div class="col-md-6">
              <label class="form-label">Tree Name</label>
              <input type="text" class="form-control" id="editName" name="name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Description</label>
              <input type="text" class="form-control" id="editDescription" name="description" required>
            </div>
            <div class="col-12">
              <label class="form-label">Image URL (Link ảnh)</label>
              <input type="url" class="form-control" id="editImage" name="image" 
                     placeholder="https://i.imgur.com/abc123.jpg">
              <small class="text-muted">Để trống nếu muốn giữ nguyên ảnh cũ</small>
            </div>
          </div>

          <!-- Preview ảnh hiện tại -->
          <div class="mt-4" id="currentImagePreview" style="display: none;">
            <p><strong>Ảnh hiện tại:</strong></p>
            <img id="previewImage" src="" alt="" 
                 style="max-height: 180px; border-radius: 8px; border: 1px solid #ddd;" 
                 onerror="this.style.display='none';">
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="submitEditForm()">Save Changes</button>
      </div>
    </div>
  </div>
</div>
<script>
function openEditModal(id, name, description, image) {
  document.getElementById('treeId').value = id;
  document.getElementById('editName').value = name;
  document.getElementById('editDescription').value = description;
  document.getElementById('editImage').value = image || '';

  // Hiển thị preview ảnh hiện tại
  const previewDiv = document.getElementById('currentImagePreview');
  const previewImg = document.getElementById('previewImage');
  
  if (image) {
    previewImg.src = image;
    previewDiv.style.display = 'block';
  } else {
    previewDiv.style.display = 'none';
  }

  // Đặt action form động
  document.getElementById('editTreeForm').action = `/trees/edit/${id}`;

  // Mở modal
  const modal = new bootstrap.Modal(document.getElementById('editTreeModal'));
  modal.show();
}

function submitEditForm() {
  document.getElementById('editTreeForm').submit();
}
</script>



</body>
</html>