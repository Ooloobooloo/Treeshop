<!doctype html>
<html lang="en" class="light-style layout-navbar-fixed layout-menu-fixed layout-compact" dir="ltr"
  data-theme="theme-default" data-assets-path="/assets/" data-template="vertical-menu-template" data-style="light">
<head>
  <%- include('partials/header') %>
</head>
<body>
  <div class="layout-wrapper layout-content-navbar">
    <div class="layout-container">

      <!-- Vertical Navigation -->
      <%- include('partials/vertical_nav', { currentPage: 'trees' }) %>

      <div class="layout-page">
        <div class="content-wrapper">
          <div class="container-xxl flex-grow-1 container-p-y">

            <% if (error) { %>
              <div class="alert alert-warning mb-4"><%= error %></div>
            <% } %>

            <h4 class="mb-4 fw-semibold">Tree Management</h4>

            <!-- Tree List Content -->
            <div id="treeListContent">
              <div class="card">
                <div class="card-body">
                  <div class="table-responsive text-nowrap">
                    <table class="table table-hover">
                      <thead>
                        <tr>
                          <th>Tree Name</th>
                          <th>Description</th>
                          <th>Image</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody class="table-border-bottom-0">
                        <% if (trees && trees.length > 0) { %>
                          <% trees.forEach(tree => { %>
                            <tr>
                              <td><i class="ri-leaf-fill ri-22px text-success me-4"></i><%= tree.name %></td>
                              <td><%= tree.description || 'Chưa có mô tả' %></td>
                              <td>
                                <% if (tree.image) { %>
                                  <img src="<%= tree.image %>" alt="<%= tree.name %>" 
                                       style="max-height: 60px; width: auto; object-fit: cover;"
                                       onerror="this.onerror=null; this.src='https://placehold.co/100x60?text=No+Image';">
                                <% } else { %>
                                  <span class="text-muted">-</span>
                                <% } %>
                              </td>
                              <td>
                                <div class="dropdown">
                                  <button type="button" class="btn p-0 dropdown-toggle hide-arrow" data-bs-toggle="dropdown">
                                    <i class="ri-more-2-line"></i>
                                  </button>
                                  <div class="dropdown-menu">
                                    <a href="javascript:void(0);" class="dropdown-item waves-effect"
                                       onclick="openEditModal('<%= tree._id %>', '<%= tree.name.replace(/'/g, "\\'") %>', '<%= tree.description.replace(/'/g, "\\'") %>', '<%= tree.image || "" %>')">
                                      <i class="ri-pencil-line me-1"></i> Edit
                                    </a>
                                    <form action="/trees/delete/<%= tree._id %>" method="POST" style="display: inline;">
                                      <button type="submit" class="dropdown-item text-danger waves-effect"
                                              onclick="return confirm('Bạn có chắc muốn xóa cây <%= tree.name %>?')">
                                        <i class="ri-delete-bin-6-line me-1"></i> Delete
                                      </button>
                                    </form>
                                  </div>
                                </div>
                              </td>
                            </tr>
                          <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Chưa có cây nào.</td>
                          </tr>
                        <% } %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>

            <!-- Add New Tree Content (ẩn ban đầu) -->
            <div id="addTreeContent" style="display: none;">
              <div class="card">
                <h5 class="card-header">Add New Tree</h5>
                <div class="card-body">
                  <form action="/trees" method="POST">
                    <div class="row g-4">
                      <div class="col-md-4">
                        <label class="form-label">Name</label>
                        <input class="form-control" type="text" name="name" placeholder="Tree Name" required>
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Description</label>
                        <input class="form-control" type="text" name="description" placeholder="Description" required>
                      </div>
                      <div class="col-md-4">
                        <label class="form-label">Image URL</label>
                        <input class="form-control" type="url" name="image" placeholder="https://i.imgur.com/abc123.jpg">
                      </div>
                    </div>
                    <div class="mt-4 d-flex gap-2">
                      <button type="submit" class="btn btn-primary">Add Tree</button>
                      <button type="submit" formaction="/reset" class="btn btn-outline-danger">Reset All</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ==================== EDIT MODAL ==================== -->
  <div class="modal fade" id="editTreeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Edit Tree</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="editTreeForm" method="POST">
            <input type="hidden" id="treeId" name="id">

            <div class="row g-4">
              <div class="col-md-6">
                <label class="form-label">Tree Name</label>
                <input type="text" class="form-control" id="editName" name="name" required>
              </div>
              <div class="col-md-6">
                <label class="form-label">Description</label>
                <input type="text" class="form-control" id="editDescription" name="description" required>
              </div>
              <div class="col-12">
                <label class="form-label">Image URL</label>
                <input type="url" class="form-control" id="editImage" name="image">
                <small class="text-muted">Dán link ảnh mới nếu muốn thay đổi</small>
              </div>
            </div>

            <div class="mt-3" id="imagePreview">
              <p><strong>Ảnh hiện tại:</strong></p>
              <img id="previewImg" src="" style="max-height: 180px; border-radius: 8px;" onerror="this.style.display='none'">
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
          <button type="button" class="btn btn-primary" onclick="submitEdit()">Lưu thay đổi</button>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script>
    // Chuyển đổi giữa Tree List và Add Tree từ Vertical Nav
    function switchTo(tab) {
      if (tab === 'list') {
        document.getElementById('treeListContent').style.display = 'block';
        document.getElementById('addTreeContent').style.display = 'none';
      } else if (tab === 'add') {
        document.getElementById('treeListContent').style.display = 'none';
        document.getElementById('addTreeContent').style.display = 'block';
      }
    }

    // Mở Modal Edit
    function openEditModal(id, name, description, image) {
      document.getElementById('treeId').value = id;
      document.getElementById('editName').value = name;
      document.getElementById('editDescription').value = description;
      document.getElementById('editImage').value = image || '';

      const previewDiv = document.getElementById('imagePreview');
      const previewImg = document.getElementById('previewImg');
      
      if (image) {
        previewImg.src = image;
        previewDiv.style.display = 'block';
      } else {
        previewDiv.style.display = 'none';
      }

      // Set action cho form
      document.getElementById('editTreeForm').action = `/trees/edit/${id}`;

      // Hiển thị modal
      const modal = new bootstrap.Modal(document.getElementById('editTreeModal'));
      modal.show();
    }

    function submitEdit() {
      document.getElementById('editTreeForm').submit();
    }
  </script>
</body>
</html>